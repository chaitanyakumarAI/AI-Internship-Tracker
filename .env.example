# ── Notion ────────────────────────────────────────────────────────────────────
NOTION_API_KEY=your_notion_integration_secret
NOTION_DATABASE_ID=your_notion_database_id

# ── Google Gemini (free at https://aistudio.google.com) ───────────────────────
GEMINI_API_KEY=your_gemini_api_key

# ── Telegram Bot ──────────────────────────────────────────────────────────────
# Create a bot via @BotFather on Telegram to get these
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ── Gmail OAuth ───────────────────────────────────────────────────────────────
# These are set automatically from credentials.json and token.json
# For GitHub Actions, paste the full JSON contents of each file as secrets
GMAIL_CREDENTIALS_JSON=
GMAIL_TOKEN_JSON=

# ── Optional Settings ─────────────────────────────────────────────────────────
GMAIL_MAX_RESULTS=50       # Number of emails to fetch per run
POLL_INTERVAL_HOURS=3      # Scheduler interval (used by scheduler.py)
LOG_LEVEL=INFO             # DEBUG, INFO, WARNING, ERROR
